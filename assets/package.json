{
  "name": "protosite-palette",
  "version": "3.8.17",
  "homepage": "http://palette.protosite.xyz",
  "type": "module",
  "files": [
    "./*"
  ],
  "exports": {
    ".": {
      "import": "./protosite-palette.mjs",
      "require": "./protosite-palette.cjs",
      "types": "./protosite-palette.d.ts"
